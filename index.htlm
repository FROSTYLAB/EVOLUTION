<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Frosty Lab Tycoon - Phaser Edition</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser-arcade-physics.min.js"></script>
    <style>
        body { margin: 0; background: #000; display: flex; justify-content: center; align-items: center; height: 100vh; overflow: hidden; }
        canvas { border: 4px solid #38bdf8; border-radius: 20px; box-shadow: 0 0 40px rgba(56, 189, 248, 0.3); }
    </style>
</head>
<body>

<script>
    // CONFIGURATION DU MOTEUR
    const config = {
        type: Phaser.AUTO,
        width: 800,
        height: 600,
        backgroundColor: '#1e293b',
        physics: {
            default: 'arcade',
            arcade: { debug: false }
        },
        scene: {
            preload: preload,
            create: create,
            update: update
        }
    };

    const game = new Phaser.Game(config);
    let score = 0;
    let scoreText;
    let customers;
    let ingredients = [];

    // 1. CHARGEMENT DES ASSETS
    function preload() {
        // En prod, tu remplaceras par tes propres images sur GitHub
        this.load.image('truck', 'https://labs.phaser.io/assets/sprites/car95.png');
        this.load.image('fruit', 'https://labs.phaser.io/assets/sprites/apple.png');
        this.load.image('particle', 'https://labs.phaser.io/assets/particles/blue.png');
    }

    // 2. CRÉATION DU MONDE
    function create() {
        // Fond dégradé (simulé avec des formes)
        let graphics = this.add.graphics();
        graphics.fillGradientStyle(0x0f172a, 0x0f172a, 0x1e293b, 0x1e293b, 1);
        graphics.fillRect(0, 0, 800, 600);

        // Interface UI
        scoreText = this.add.text(20, 20, 'CA : 0€', { fontSize: '32px', fontWeight: 'bold', fill: '#38bdf8', fontFamily: 'Arial' });
        
        // Notre Truck (Le joueur)
        const truck = this.add.sprite(400, 500, 'truck').setScale(1.5);
        truck.setInteractive();

        // Groupe de clients (on pourra en ajouter à l'infini)
        customers = this.add.group();

        // Création des bacs d'ingrédients interactifs
        const flavors = ['Vanilla', 'Mango', 'Coco'];
        flavors.forEach((name, i) => {
            let bin = this.add.rectangle(150 + (i * 250), 540, 200, 80, 0x334155).setInteractive();
            let label = this.add.text(150 + (i * 250), 540, name, { fontSize: '20px', fill: '#fff' }).setOrigin(0.5);
            
            bin.on('pointerdown', () => {
                this.addParticle(150 + (i * 250), 540);
                score += 5;
                scoreText.setText('CA : ' + score + '€');
                
                // Animation de clic
                this.tweens.add({
                    targets: [bin, label],
                    scale: 0.9,
                    duration: 100,
                    yoyo: true
                });
            });
        });

        // Apparition d'un premier client après 1 seconde
        this.time.addEvent({ delay: 2000, callback: spawnCustomer, callbackScope: this, loop: true });
    }

    // 3. LOGIQUE EN TEMPS RÉEL (60 FPS)
    function update() {
        // Ici on pourra gérer les déplacements fluides ou les timers
    }

    // FONCTION : APPARITION CLIENT
    function spawnCustomer() {
        let x = 900;
        let y = 250;
        let customer = this.add.text(x, y, '😋', { fontSize: '60px' });
        
        // Déplacement fluide vers le truck avec un Tween Phaser
        this.tweens.add({
            targets: customer,
            x: Phaser.Math.Between(100, 700),
            duration: 3000,
            ease: 'Power2',
            onComplete: () => {
                // Bulle de commande
                let bubble = this.add.circle(customer.x + 40, customer.y - 20, 30, 0xffffff);
                let order = this.add.text(customer.x + 30, customer.y - 30, '🍦', { fontSize: '20px', fill: '#000' });
            }
        });
    }

    // FONCTION : EFFET PARTICULES
    function addParticle(x, y) {
        const emitter = this.add.particles(x, y, 'particle', {
            speed: 100,
            scale: { start: 0.5, end: 0 },
            blendMode: 'ADD',
            lifespan: 500,
            gravityY: 200,
            maxParticles: 10
        });
    }
</script>

</body>
</html>
