<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Frosty Lab - EVOLUTION</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser-arcade-physics.min.js"></script>
    <style>
        body { margin: 0; background: #020617; display: flex; justify-content: center; align-items: center; height: 100vh; overflow: hidden; font-family: sans-serif; }
        #game-container { border: 4px solid #38bdf8; border-radius: 24px; box-shadow: 0 0 50px rgba(56, 189, 248, 0.2); }
    </style>
</head>
<body>

<div id="game-container"></div>

<script>
    const config = {
        type: Phaser.AUTO,
        parent: 'game-container',
        width: 800,
        height: 600,
        backgroundColor: '#0f172a',
        physics: { default: 'arcade' },
        scene: { preload: preload, create: create, update: update }
    };

    const game = new Phaser.Game(config);

    let score = 0;
    let scoreText;
    let currentOrder = [];
    let activeCustomer = null;
    let flavorBins = [];
    const flavors = [
        { name: 'Vanille', color: 0xfef08a },
        { name: 'Fraise', color: 0xf87171 },
        { name: 'Choco', color: 0x78350f },
        { name: 'Mango', color: 0xfb923c },
        { name: 'Coco', color: 0xf8fafc },
        { name: 'Menthe', color: 0x4ade80 }
    ];

    function preload() {
        // Assets de secours
        this.load.image('particle', 'https://labs.phaser.io/assets/particles/blue.png');
    }

    function create() {
        // --- DÉCOR ---
        let graphics = this.add.graphics();
        graphics.fillGradientStyle(0x1e293b, 0x1e293b, 0x0f172a, 0x0f172a, 1);
        graphics.fillRect(0, 0, 800, 600);

        // Ligne de séparation (Comptoir)
        graphics.lineStyle(4, 0x38bdf8, 0.3);
        graphics.lineBetween(0, 400, 800, 400);

        // --- UI ---
        scoreText = this.add.text(400, 40, 'RECETTE : 0€', { fontSize: '32px', fontWeight: 'bold', fill: '#38bdf8' }).setOrigin(0.5);
        this.add.text(400, 80, 'MODE EVOLUTION', { fontSize: '14px', fill: '#64748b' }).setOrigin(0.5);

        // --- BOUTONS / BACS ---
        flavors.forEach((flavor, i) => {
            let x = 100 + (i % 3) * 300;
            let y = 460 + (Math.floor(i / 3) * 80);
            
            let btn = this.add.container(x, y);
            let rect = this.add.rectangle(0, 0, 240, 60, flavor.color, 1).setInteractive({ cursor: 'pointer' });
            rect.setStrokeStyle(2, 0xffffff, 0.5);
            
            let text = this.add.text(0, 0, flavor.name.toUpperCase(), { fontSize: '18px', fontWeight: 'bold', fill: flavor.name === 'Vanille' || flavor.name === 'Coco' ? '#000' : '#fff' }).setOrigin(0.5);
            
            btn.add([rect, text]);

            rect.on('pointerdown', () => {
                this.tweens.add({ targets: btn, scale: 0.95, duration: 50, yoyo: true });
                serveFlavor(this, flavor);
            });
        });

        // --- CORNET DE PRÉPARATION ---
        this.coneContainer = this.add.container(400, 360);
        this.coneEmoji = this.add.text(0, 0, '🍦', { fontSize: '64px' }).setOrigin(0.5);
        this.coneContainer.add(this.coneEmoji);

        // Premier client
        spawnCustomer(this);
    }

    function update() {
        // Logique de pulsation du texte de score
    }

    function spawnCustomer(scene) {
        if (activeCustomer) return;

        let emoji = ['👨‍🦰', '👧', '👮', '🐱', '🤖'][Math.floor(Math.random() * 5)];
        let xStart = 900;
        
        let container = scene.add.container(xStart, 250);
        let char = scene.add.text(0, 0, emoji, { fontSize: '80px' }).setOrigin(0.5);
        
        // Générer commande
        let numScoops = Phaser.Math.Between(1, 3);
        let order = [];
        for(let i=0; i<numScoops; i++) order.push(flavors[Phaser.Math.Between(0, 5)]);

        // Bulle de pensée
        let bubble = scene.add.graphics();
        bubble.fillStyle(0xffffff, 1);
        bubble.fillRoundedRect(40, -100, 120, order.length * 25 + 20, 15);
        
        let orderText = scene.add.text(100, -90 + (order.length * 12), order.map(f => f.name).join('\n'), { 
            fontSize: '14px', fill: '#000', fontWeight: 'bold', align: 'center' 
        }).setOrigin(0.5);

        container.add([char, bubble, orderText]);

        scene.tweens.add({
            targets: container,
            x: 200,
            duration: 1000,
            ease: 'Back.easeOut',
            onComplete: () => { activeCustomer = { container, order }; }
        });
    }

    function serveFlavor(scene, flavor) {
        if (!activeCustomer) return;

        currentOrder.push(flavor);
        
        // Effet de particule
        let emitter = scene.add.particles(400, 320, 'particle', {
            speed: 150, scale: { start: 0.4, end: 0 }, lifespan: 400, gravityY: 300, maxParticles: 10,
            tint: flavor.color
        });

        // Ajouter la boule visuelle
        let scoop = scene.add.circle(0, -30 - (currentOrder.length * 25), 30, flavor.color);
        scoop.setStrokeStyle(2, 0x000000, 0.2);
        scene.coneContainer.add(scoop);

        // Vérification
        let target = activeCustomer.order[currentOrder.length - 1];
        if (flavor.name !== target.name) {
            // ERREUR
            scene.cameras.main.shake(200, 0.01);
            resetOrder(scene);
        } else if (currentOrder.length === activeCustomer.order.length) {
            // SUCCÈS
            score += 10 + (currentOrder.length * 5);
            scoreText.setText('RECETTE : ' + score + '€');
            
            scene.tweens.add({
                targets: activeCustomer.container,
                x: -200,
                alpha: 0,
                duration: 500,
                onComplete: () => {
                    activeCustomer.container.destroy();
                    activeCustomer = null;
                    resetOrder(scene);
                    scene.time.delayedCall(1000, () => spawnCustomer(scene));
                }
            });
        }
    }

    function resetOrder(scene) {
        currentOrder = [];
        scene.coneContainer.iterate(child => {
            if (child !== scene.coneEmoji) {
                scene.tweens.add({
                    targets: child,
                    y: 600,
                    alpha: 0,
                    duration: 400,
                    onComplete: () => child.destroy()
                });
            }
        });
    }
</script>

</body>
</html>
